{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "JobStatus",
  "type": "object",
  "properties": {
    "job_id": { "type": "string" },
    "status": { "type": "string", "enum": ["queued", "processing", "completed", "failed", "cancelled"] },
    "progress": { "type": "number", "minimum": 0, "maximum": 1, "description": "0.0 to 1.0" },
    "message": { "type": "string" },
    "warnings": { "type": "array", "items": { "type": "string" } }
  },
  "required": ["job_id", "status", "progress"]
}
